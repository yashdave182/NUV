# AgriTech API Environment Configuration
# Copy to .env and fill in your API keys

# Weather APIs (get free keys from respective providers)
OPENWEATHER_API_KEY=
WEATHERAPI_KEY=
IMD_API_KEY=
VISUALCROSSING_API_KEY=

# Market Data APIs
AGMARKNET_API_KEY=your_agmarknet_key_here
DATA_GOV_IN_API_KEY=579b464db66ec23bdd000001965628669cf6433b6759af2e46eb3d13

# Satellite Data
SENTINEL_HUB_CLIENT_ID=your_sentinelhub_client_id
SENTINEL_HUB_CLIENT_SECRET=your_sentinelhub_client_secret
GEE_API_KEY=your_google_earth_engine_key
NASA_POWER_API_KEY=your_nasa_power_key

# Soil Health
ICAR_SOIL_API_KEY=your_icar_soil_key
SOIL_HEALTH_CARD_API=https://api.soilhealth.dac.gov.in
STATE_SOIL_PORTAL_URL=https://soilhealth.dac.gov.in

# AI/ML Providers (for SMS backend)
GROQ_API_KEY_1=your_groq_key_1
GROQ_API_KEY_2=your_groq_key_2
GEMINI_API_KEY_1=your_gemini_key_1
GEMINI_API_KEY_2=your_gemini_key_2

# Database (optional)
DATABASE_URL=postgresql://user:pass@localhost:5432/agritech
REDIS_URL=redis://localhost:6379/0

# Application Settings
APP_ENV=development
LOG_LEVEL=INFO
MODEL_DIR=./models
REPORTS_DIR=./reports
CACHE_TTL=3600

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# ThingSpeak IoT Telemetry
THINGSPEAK_CHANNEL_ID=3430931
THINGSPEAK_READ_API_KEY=ISU4ALDTZJDI30KF